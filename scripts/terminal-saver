#!/usr/bin/env bash
set -euo pipefail

readonly TTY_DEVICE="/dev/tty"
readonly DEFAULT_INTERVAL="0.2"
readonly DEFAULT_MESSAGE="terminal screensaver"
readonly ROOT_DIR="${DOTFILES_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
readonly GHOSTTY_CAPTURE_SCRIPT="$ROOT_DIR/scripts/ghostty-capture-buffer"
readonly -a DEFAULT_EFFECTS=(
  beams
  blackhole
  bubbles
  burn
  decrypt
  fireworks
  matrix
  overflow
  rain
  rings
  spotlights
  spray
  synthgrid
  thunderstorm
  vhstape
  waves
  wipe
)

usage() {
  cat <<'EOF'
Usage: terminal-saver [options] [effect] [-- effect-options...]

Animate a full-terminal text effect until a key is pressed.

Options:
  -s, --screen       Animate the currently visible Ghostty screen
  -b, --back         Animate the full Ghostty scrollback buffer
  -f, --fill         Animate generated fullscreen filler text
  --effect NAME      Use a specific TTE effect. Default: random
  --message TEXT     Base text used to fill the screen
  --interval SEC     Delay between loops when cycling effects (default: 0.2)
  --once             Run a single animation and exit
  --list             Print the default random effect pool
  -h, --help         Show this help

Examples:
  terminal-saver
  terminal-saver -s
  terminal-saver -b
  terminal-saver -f
  terminal-saver matrix
  terminal-saver --effect rain --message "away for coffee"
  terminal-saver --effect synthgrid -- --final-gradient-direction horizontal
EOF
}

effect="random"
message="${TTE_SAVER_MESSAGE:-$DEFAULT_MESSAGE}"
interval="$DEFAULT_INTERVAL"
once=0
list_only=0
source_mode="screen"
effect_args=()

while (($#)); do
  case "$1" in
    -s|--screen)
      source_mode="screen"
      shift
      ;;
    -b|--back|--scrollback)
      source_mode="scrollback"
      shift
      ;;
    -f|--fill)
      source_mode=""
      shift
      ;;
    --effect)
      [[ $# -ge 2 ]] || { echo "missing value for --effect" >&2; exit 1; }
      effect="$2"
      shift 2
      ;;
    --message)
      [[ $# -ge 2 ]] || { echo "missing value for --message" >&2; exit 1; }
      message="$2"
      shift 2
      ;;
    --interval)
      [[ $# -ge 2 ]] || { echo "missing value for --interval" >&2; exit 1; }
      interval="$2"
      shift 2
      ;;
    --once)
      once=1
      shift
      ;;
    --list)
      list_only=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      effect_args=("$@")
      break
      ;;
    -*)
      echo "unknown option: $1" >&2
      exit 1
      ;;
    *)
      if [[ "$effect" == "random" ]]; then
        effect="$1"
        shift
      else
        effect_args+=("$1")
        shift
      fi
      ;;
  esac
done

if [[ "$list_only" == "1" ]]; then
  printf '%s\n' "${DEFAULT_EFFECTS[@]}"
  exit 0
fi

if ! command -v tte >/dev/null 2>&1; then
  echo "tte is not installed. Rebuild this dotfiles config first." >&2
  exit 1
fi

if [[ ! -r "$TTY_DEVICE" || ! -w "$TTY_DEVICE" ]]; then
  echo "terminal-saver requires an interactive terminal." >&2
  exit 1
fi

stty_state="$(stty -g < "$TTY_DEVICE")"
tmpdir="$(mktemp -d)"
source_file="${TTE_SAVER_SOURCE_FILE:-}"
delete_source_file="${TTE_SAVER_SOURCE_FILE_DELETE:-0}"

cleanup() {
  stty "$stty_state" < "$TTY_DEVICE" 2>/dev/null || true
  printf '\033[0m\033[?25h\033[?1049l' > "$TTY_DEVICE" 2>/dev/null || true
  if [[ "$delete_source_file" == "1" && -n "$source_file" ]]; then
    rm -f "$source_file"
  fi
  rm -rf "$tmpdir"
}

trap cleanup EXIT INT TERM

pick_effect() {
  if [[ "$effect" != "random" ]]; then
    printf '%s\n' "$effect"
    return
  fi

  local idx=$((RANDOM % ${#DEFAULT_EFFECTS[@]}))
  printf '%s\n' "${DEFAULT_EFFECTS[$idx]}"
}

center_line() {
  local width="$1"
  local text="$2"

  if ((${#text} >= width)); then
    printf '%s\n' "${text:0:width}"
    return
  fi

  local pad=$(((width - ${#text}) / 2))
  printf '%*s%s%*s\n' "$pad" "" "$text" "$((width - pad - ${#text}))" ""
}

pattern_line() {
  local width="$1"
  local seed="$2"
  local line=""

  while ((${#line} < width)); do
    line+="$seed"
  done

  printf '%s\n' "${line:0:width}"
}

render_frame() {
  local cols lines host short_pwd stamp seed fill_rows row

  cols="$(tput cols 2>/dev/null || printf '80')"
  lines="$(tput lines 2>/dev/null || printf '24')"
  host="$(hostname -s 2>/dev/null || hostname)"
  short_pwd="${PWD/#$HOME/~}"
  stamp="$(date '+%A %d %B %Y  %H:%M:%S')"
  seed=" ${message} :: ${host} :: "

  ((cols < 20)) && cols=20
  ((lines < 8)) && lines=8

  center_line "$cols" "Press any key to return"
  center_line "$cols" "${message}"
  center_line "$cols" "$stamp"
  center_line "$cols" "$host  ${short_pwd}"

  fill_rows=$((lines - 5))
  for ((row = 0; row < fill_rows; row++)); do
    pattern_line "$cols" "$seed"
  done
}

ensure_source_file() {
  if [[ -n "$source_file" ]]; then
    return
  fi

  if [[ -n "$source_mode" ]]; then
    if [[ ! -x "$GHOSTTY_CAPTURE_SCRIPT" ]]; then
      echo "missing capture helper: $GHOSTTY_CAPTURE_SCRIPT" >&2
      exit 1
    fi

    source_file="$tmpdir/source.txt"
    "$GHOSTTY_CAPTURE_SCRIPT" "$source_mode" > "$source_file"
  fi
}

stty -echo -icanon min 0 time 0 < "$TTY_DEVICE"
printf '\033[?1049h\033[2J\033[H\033[?25l' > "$TTY_DEVICE"
ensure_source_file

while :; do
  frame_file="$tmpdir/frame.txt"
  current_effect="$(pick_effect)"

  if [[ -n "$source_file" ]]; then
    cp "$source_file" "$frame_file"
  else
    render_frame > "$frame_file"
  fi

  tte "$current_effect" "${effect_args[@]}" < "$frame_file" > "$TTY_DEVICE" 2> "$TTY_DEVICE" &
  tte_pid=$!
  stop_requested=0

  while kill -0 "$tte_pid" 2>/dev/null; do
    if IFS= read -rsn1 -t 0.1 _ < "$TTY_DEVICE"; then
      stop_requested=1
      kill "$tte_pid" 2>/dev/null || true
      break
    fi
  done

  wait "$tte_pid" 2>/dev/null || true

  if [[ "$stop_requested" == "1" || "$once" == "1" ]]; then
    break
  fi

  sleep "$interval"
  printf '\033[2J\033[H' > "$TTY_DEVICE"
done
