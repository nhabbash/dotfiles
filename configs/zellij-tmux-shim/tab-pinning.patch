 # Helpers
 # ---------------------------------------------------------------------------

+# --- Tab pinning ---
+# Limitation: zellij CLI has no way to create a pane in a specific tab without
+# switching focus to it first. There is no --tab-index flag on `new-pane`.
+# The plugin API has `move_panes_to_tab` but that requires a WASM plugin.
+# As a workaround, we switch to the team tab, create the pane, then switch back.
+# This causes a brief visual flicker but keeps agent panes in the correct tab.
+#
+# If zellij adds tab-targeted pane creation in the future, this can be simplified
+# to pass the tab index directly to `new-pane`.
+
+# Get the 1-based index of the currently focused tab
+get_current_tab_index() {
+    local idx=0
+    while IFS= read -r line; do
+        idx=$((idx + 1))
+        if echo "$line" | grep -q 'focus=true'; then
+            echo "$idx"
+            return 0
+        fi
+    done < <(zellij action dump-layout 2>/dev/null | grep '^\s*tab ')
+    echo "1"
+}
+
+# Record the team lead's tab on first call, return it on subsequent calls.
+# Prefers the per-pane index written by activate.sh at shell startup — captured
+# before the user can switch tabs. Falls back to the current focused tab.
+get_team_tab() {
+    local team_tab_file="${STATE_DIR}/team_tab"
+    if [ -f "$team_tab_file" ]; then
+        cat "$team_tab_file"
+    else
+        local pane_tab_file="${STATE_DIR}/pane_tab_idx_${ZELLIJ_PANE_ID:-0}"
+        local idx
+        if [ -f "$pane_tab_file" ]; then
+            idx=$(cat "$pane_tab_file")
+        else
+            idx=$(get_current_tab_index)
+        fi
+        echo "$idx" > "$team_tab_file"
+        echo "$idx"
+    fi
+}
+
+# Switch to the team tab if not already there, return the original tab index.
+# Caller should switch back after pane creation with restore_user_tab.
+ensure_team_tab() {
+    local team_tab current_tab
+    team_tab=$(get_team_tab)
+    current_tab=$(get_current_tab_index)
+    if [ "$current_tab" != "$team_tab" ]; then
+        log_debug "tab-pin: switching from tab $current_tab to team tab $team_tab"
+        zellij action go-to-tab "$team_tab" 2>/dev/null
+    fi
+    echo "$current_tab"
+}
+
+# Switch back to where the user was before we created the pane
+restore_user_tab() {
+    local original_tab="$1" team_tab
+    team_tab=$(get_team_tab)
+    if [ "$original_tab" != "$team_tab" ]; then
+        log_debug "tab-pin: restoring user to tab $original_tab"
+        zellij action go-to-tab "$original_tab" 2>/dev/null
+    fi
+}
+
