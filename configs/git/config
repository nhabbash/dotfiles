[user]
	name = Nassim Habbash
	email = nassim@habbash.dev

[push]
	autoSetupRemote = true

[init]
	defaultBranch = main
	templateDir = /Users/nassim/dotfiles/.git-template

[pull]
	rebase = true

[core]
	editor = nvim
	excludesFile = /Users/nassim/.config/git/ignore

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate

[include]
	path = ~/.gitconfig.local
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
