--- a/activate.sh	2026-03-13 15:14:25
+++ b/activate.sh	2026-03-14 18:00:00
@@ -104,4 +104,20 @@
 rm -f "$ZELLIJ_TMUX_SHIM_STATE/parent.env"
 rm -rf "$ZELLIJ_TMUX_SHIM_STATE/next_id.lock"
+rm -f "$ZELLIJ_TMUX_SHIM_STATE/team_tab"

+# Record the focused tab index for this pane at shell startup.
+# Shell startup guarantees we are the focused tab (the user just opened us).
+# The tmux shim reads this to find the team lead's tab even if the user
+# switches to another tab before the first agent spawns.
+# Scoped by ZELLIJ_PANE_ID so multiple Claude Code tabs don't collide.
+if [ -n "${ZELLIJ_PANE_ID:-}" ]; then
+    _tab_idx=0
+    while IFS= read -r _line; do
+        _tab_idx=$((_tab_idx + 1))
+        echo "$_line" | grep -q 'focus=true' && break
+    done < <(zellij action dump-layout 2>/dev/null | grep '^\s*tab ')
+    [ "$_tab_idx" -gt 0 ] && echo "$_tab_idx" > "${ZELLIJ_TMUX_SHIM_STATE}/pane_tab_idx_${ZELLIJ_PANE_ID}"
+    unset _tab_idx _line
+fi
+
