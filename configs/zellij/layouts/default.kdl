// Vertical tabs layout with zjstatus status bars
//
// Structure:
//   top:    zjstatus (session, mode, kube, time)
//   left:   vertical-tabs sidebar
//   center: main terminal pane
//   bottom: zjstatus (hints)

layout {
    // Top status bar — session, mode, kube, datetime
    pane size=1 borderless=true {
        plugin location="zjstatus" {
            // BEGIN GENERATED: zellij-default-top-theme
            format_left   "#[bg=#3E424A,fg=#7aa89f]\u{e0b6}#[bg=#7aa89f,fg=#14171d] {session} #[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        format_center "{notifications}"
                        format_right  "#[bg=#3E424A,fg=#e46876]\u{e0b6}#[bg=#e46876,fg=#14171d]\u{f00ed}#[bg=#5C6066,fg=#e46876]\u{e0b4} {datetime}#[bg=#3E424A,fg=#5C6066]\u{e0b4}"
                        format_space  "#[bg=#3E424A]"
                        format_hide_on_overlength "true"
                        format_precedence "lrc"

                        notification_format_unread           "#[bg=#e6c384,fg=#14171d,blink] \u{f0f3} #[bg=#5C6066,fg=#e6c384]\u{e0b4} {message}#[bg=#3E424A,fg=#5C6066]\u{e0b4}"
                        notification_format_no_notifications ""
                        notification_show_interval           "10"

                        mode_normal        "#[bg=#7fb4ca,fg=#14171d] NORMAL#[bg=#3E424A,fg=#7fb4ca]\u{e0b4}"
                        mode_locked        "#[bg=#e46876,fg=#14171d] LOCKED#[bg=#3E424A,fg=#e46876]\u{e0b4}"
                        mode_pane          "#[bg=#7aa89f,fg=#14171d] PANE#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_tab           "#[bg=#7aa89f,fg=#14171d] TAB#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_scroll        "#[bg=#7aa89f,fg=#14171d] SCROLL#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_search        "#[bg=#7aa89f,fg=#14171d] SEARCH#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_enter_search  "#[bg=#7aa89f,fg=#14171d] ENT-SEARCH#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_resize        "#[bg=#e6c384,fg=#14171d] RESIZE#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_rename_tab    "#[bg=#e6c384,fg=#14171d] RENAME-TAB#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_rename_pane   "#[bg=#e6c384,fg=#14171d] RENAME-PANE#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_move          "#[bg=#e6c384,fg=#14171d] MOVE#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_session       "#[bg=#938aa9,fg=#14171d] SESSION#[bg=#3E424A,fg=#938aa9]\u{e0b4}"
                        mode_prompt        "#[bg=#938aa9,fg=#14171d] PROMPT#[bg=#3E424A,fg=#938aa9]\u{e0b4}"
            // END GENERATED: zellij-default-top-theme

            datetime        "{format}"
            datetime_format "%d %b %H:%M:%S"

        }
    }

    // Main area: sidebar + content
    pane split_direction="vertical" {
        // Vertical tab sidebar
        pane size=20 borderless=true {
            plugin location="https://github.com/cfal/zellij-vertical-tabs/releases/download/v0.1.0/zellij-vertical-tabs.wasm" {
                // BEGIN GENERATED: zellij-default-vertical-tabs-theme
                format        " #[fg=#7fb4ca]\u{e0b6}#[bg=#7fb4ca,fg=#14171d]{index}#[bg=none,fg=#7fb4ca]\u{e0b4} {=12:name}"
                                format_active " #[fg=#e6c384]\u{e0b6}#[bg=#e6c384,fg=#14171d]{index}#[bg=none,fg=#e6c384]\u{e0b4} {=12:name}"
                // END GENERATED: zellij-default-vertical-tabs-theme
                max_name_length 12
                overflow_above "  ^ +{count}"
                overflow_below "  v +{count}"
                padding_top 1
            }
        }
        // Terminal
        pane focus=true
    }

    // Bottom status bar — mode + hints
    pane size=1 borderless=true {
        plugin location="zjstatus" {
            format_left   "  {mode}"
            format_center ""
            format_right  "{pipe_zjstatus_hints}"
            format_hide_on_overlength "true"
            format_precedence "lrc"
            // BEGIN GENERATED: zellij-default-bottom-theme
            format_space  "#[bg=#3E424A]"

                        mode_normal        "[bg=#3E424A,fg=#7fb4ca]\u{e0b6}#[bg=#7fb4ca,fg=#14171d]NORMAL#[bg=#3E424A,fg=#7fb4ca]\u{e0b4}"
                        mode_locked        "[bg=#3E424A,fg=#e46876]\u{e0b6}#[bg=#e46876,fg=#14171d]LOCKED#[bg=#3E424A,fg=#e46876]\u{e0b4}"
                        mode_pane          "[bg=#3E424A,fg=#7aa89f]\u{e0b6}#[bg=#7aa89f,fg=#14171d]PANE#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_tab           "[bg=#3E424A,fg=#7aa89f]\u{e0b6}#[bg=#7aa89f,fg=#14171d]TAB#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_scroll        "[bg=#3E424A,fg=#7aa89f]\u{e0b6}#[bg=#7aa89f,fg=#14171d]SCROLL#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_search        "[bg=#3E424A,fg=#7aa89f]\u{e0b6}#[bg=#7aa89f,fg=#14171d]SEARCH#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_enter_search  "[bg=#3E424A,fg=#7aa89f]\u{e0b6}#[bg=#7aa89f,fg=#14171d]ENT-SEARCH#[bg=#3E424A,fg=#7aa89f]\u{e0b4}"
                        mode_resize        "[bg=#3E424A,fg=#e6c384]\u{e0b6}#[bg=#e6c384,fg=#14171d]RESIZE#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_rename_tab    "[bg=#3E424A,fg=#e6c384]\u{e0b6}#[bg=#e6c384,fg=#14171d]RENAME-TAB#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_rename_pane   "[bg=#3E424A,fg=#e6c384]\u{e0b6}#[bg=#e6c384,fg=#14171d]RENAME-PANE#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_move          "[bg=#3E424A,fg=#e6c384]\u{e0b6}#[bg=#e6c384,fg=#14171d]MOVE#[bg=#3E424A,fg=#e6c384]\u{e0b4}"
                        mode_session       "[bg=#3E424A,fg=#938aa9]\u{e0b6}#[bg=#938aa9,fg=#14171d]SESSION#[bg=#3E424A,fg=#938aa9]\u{e0b4}"
                        mode_prompt        "[bg=#3E424A,fg=#938aa9]\u{e0b6}#[bg=#938aa9,fg=#14171d]PROMPT#[bg=#3E424A,fg=#938aa9]\u{e0b4}"
            // END GENERATED: zellij-default-bottom-theme

            pipe_zjstatus_hints_format "{output}"
        }
    }
}
